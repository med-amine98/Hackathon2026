# Copy to .env at the repo root and adjust before running `docker compose up`.
# This is the ONE .env for the whole stack (agent's platform backend, mobile
# backend) — everything now runs off the single Postgres "db" service
# defined in the root docker-compose.yml. platform/.env.example and
# backend/.env.example are kept only for standalone/local (non-docker) dev.

# ── Shared Postgres ("db" service) ─────────────────────────────────────────
POSTGRES_USER=constat
POSTGRES_PASSWORD=1234
POSTGRES_DB=constat
# Used by the api/worker containers (agent's platform backend) to reach the
# db service by name. They use the default "public" schema.
DATABASE_URL=postgresql+psycopg2://constat:1234@db:5432/constat

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=12345678
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=constat-photos
MINIO_SECURE=false

# ── Agent chat (platform/backend's /chat, wraps assistant/) ────────────────
# OpenAI-compatible chat completions endpoint. Defaults to Gemini — get a
# free key at https://aistudio.google.com/apikey. Leave LLM_API_KEY blank to
# run everything else without the agent chat working (it'll reply with a
# "not configured" message instead of erroring).
LLM_API_KEY=AQ.Ab8RN6Ivwmnw8MfKjvJyHPxc2y1g2lZDNVaKwg27XzbdkRDRxA
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.5-flash

# ── Mobile backend (mobile-api service) ─────────────────────────────────────

# API Endpoint configurations
API_URL=http://localhost:8000/api/v1
DEBUG=true

# TomTom API Key
# API Keys
TOMTOM_API_KEY=r7mr4LWOYB5WyhXK2aG0vOXc4K7CnnT9
OPENWEATHER_API_KEY=bf0648407d93e7accce0564e0f184f88

# URLs
OPENWEATHER_URL=https://api.openweathermap.org/data/2.5
TOMTOM_BASE_URL=https://api.tomtom.com/traffic/services/4
BACKEND_URL=http://localhost:8001/api/v1

# Path to the trained YOLO11/CarDD checkpoint, as seen INSIDE the api/worker
# containers (WORKDIR /app, with ./platform/backend/app bind-mounted to
# /app/app — see docker-compose.yml's api service volumes) — not a host
# path. The file lives on the host at
# platform/backend/app/weights/car_damage_yolo11.pt, which the bind mount
# already exposes at this exact container path, so app/damage_detection.py
# finds it with zero extra setup. Previous value here
# ("platform/backend/app/") was a host-relative directory, not the actual
# .pt file, and doesn't resolve to anything inside the container — that's
# why detection was silently falling back to the OpenCV heuristic instead
# of the trained model.
CAR_DAMAGE_MODEL_PATH=/app/app/weights/car_damage_yolo11.pt
