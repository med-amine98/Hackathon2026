# Copy to .env in this same folder (frontend/flutter_app/.env) and adjust.

# Mobile app's own backend (backend/, service "mobile-api" in the root
# docker-compose.yml — defaults to port 8001).
BACKEND_URL=http://localhost:8001/api/v1

# Agent's chat (platform/backend, service "api" in the root
# docker-compose.yml — published on host port 8010). Used by the floating
# agent chat bubble (presentation/widgets/agent_chat_bubble.dart).
AGENT_API_URL=http://localhost:8010

OPENAI_API_KEY=
OPENWEATHER_API_KEY=
OPENWEATHER_URL=https://api.openweathermap.org/data/2.5
TOMTOM_API_KEY=
TOMTOM_BASE_URL=https://api.tomtom.com/traffic/services/4
