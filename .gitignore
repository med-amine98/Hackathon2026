# Build artifacts
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
build/

# Python bytecode cache - notably, assurex/backend and platform/backend's
# `app` dirs are bind-mounted into their docker-compose containers for
# hot-reload, so a stray __pycache__/*.pyc sitting here can in rare cases
# get picked up over freshly-edited source.
__pycache__/
*.pyc
*.pyo

# Web related
.web/

# Database / Storage
*.db

# Symbolication folder
app.*.symbols

# Obfuscation map
app.*.map.json

# Android Studio overrides
.idea/
*.iml
*.ipr
*.iws

# Xcode overrides
.docsets/
DerivedData/
Build/
Subscription.plist
*.moved-aside
*.xcworkspace
*.xcscheme
*.xsynclog
*.xcuserstate
*.xcodeplayged

# VS Code overrides
.vscode/

# Env secrets
.env
.env.production
.env.development
.env.local
