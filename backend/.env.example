# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Template de configuration (copiez vers .env et remplissez)
# NE JAMAIS committer le fichier .env avec de vraies valeurs !
# ──────────────────────────────────────────────────────────────────────────────

# Base de données
# Ce backend partage maintenant UNE SEULE base Postgres avec le backend de
# l'agent (platform/backend) — voir le docker-compose.yml à la racine du
# repo, service "db". DB_SCHEMA isole ses tables (conversations, messages,
# users, ...) dans leur propre schéma pour éviter toute collision avec les
# tables du même nom côté agent (schéma "public").
DATABASE_URL=sqlite:///./insurance.db
# Pour le Postgres partagé (docker compose up à la racine) :
# DATABASE_URL=postgresql://constat:change_me@localhost:5433/constat
DB_SCHEMA=mobile

# JWT — Générez une clé secrète forte (ex: openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI (optionnel — fallback règles si absent)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenWeather / TomTom (optionnels — utilisés par /api/v1/prevention/data ;
# fallback vers des données statiques si absents)
OPENWEATHER_API_KEY=
TOMTOM_API_KEY=

# Redis (pour le cache — optionnel en développement)
REDIS_URL=redis://localhost:6379

# Application
APP_NAME=AI Insurance Advisor
APP_VERSION=1.0.0
DEBUG=True
