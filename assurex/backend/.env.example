# Template for standalone (non-docker) dev of the assurex backend.
# Copy to .env and adjust. Not needed when running via the root
# docker-compose.yml - that sets DATABASE_URL/DB_SCHEMA/SECRET_KEY for you.

# Defaults to a local SQLite file if unset.
DATABASE_URL=sqlite:///./assurex.db
# To point at the shared Postgres from the root docker-compose stack
# instead (run `docker compose up db` at the repo root first):
# DATABASE_URL=postgresql+psycopg2://constat:change_me@localhost:5438/constat
# DB_SCHEMA isolates assurex's tables (claims, users) in their own schema
# so they never collide with the same-named tables the agent's platform
# backend (public schema) or the mobile backend (mobile schema) use.
DB_SCHEMA=assurex

# JWT - generate a strong secret in real use (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-a-long-random-secret-key
