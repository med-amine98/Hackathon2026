# Copy to .env (or .env.local) and adjust if needed.
# Points the assurex frontend at the assurex backend. When running the
# root docker-compose stack, assurex-api is exposed on host port 8002 —
# see docker-compose.yml at the repo root.
VITE_API_BASE=http://localhost:8002/api

# Points the Damage Scanner page (src/pages/DamageScanner.jsx) directly at
# platform/backend's "api" service (owns the trained YOLO11/CarDD damage
# model) — host port 8010 via the root docker-compose, same service the
# assurex backend's PLATFORM_API_BASE already reaches for photo files.
VITE_PLATFORM_API_BASE=http://localhost:8010
