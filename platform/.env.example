# DEPRECATED — the root-level docker-compose.yml (and its .env.example) is
# now the single source of truth for the whole stack, including this
# service. Kept here only in case platform/docker-compose.yml is still used
# standalone for local dev. See /.env.example at the repo root.

# Copy to .env and adjust before running `docker compose up`

POSTGRES_USER=constat
POSTGRES_PASSWORD=change_me
POSTGRES_DB=constat
# Used by the api/worker containers to reach the db service by name:
DATABASE_URL=postgresql+psycopg2://constat:change_me@db:5432/constat

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_too
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=constat-photos
MINIO_SECURE=false
